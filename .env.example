# ============================================================
# Supabase (Phase 2)
# supabase.com/dashboard → Project Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ============================================================
# Gemini AI (Phase 5)
# aistudio.google.com/apikey
# ============================================================
GEMINI_API_KEY=AIza...

# ============================================================
# Toss Payments (Phase 4)
# IMPORTANT: Use "결제위젯 연동 키" (test_gck_* / test_gsk_*), NOT the
# "API 개별 연동 키" (test_ck_* / test_sk_*). The SDK used here
# (@tosspayments/tosspayments-sdk widgets API) requires the widget-flavour keys.
# Docs: https://docs.tosspayments.com/reference/widget-sdk
# ============================================================
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_xxx
TOSS_SECRET_KEY=test_gsk_xxx

# ============================================================
# Admin back-office
# Set ADMIN_COOKIE_SECRET to a 32+ char random string
# (e.g., `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
# ============================================================
ADMIN_PASSWORD=change-me-please
ADMIN_COOKIE_SECRET=change-me-to-a-long-random-string

# ============================================================
# Site
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
